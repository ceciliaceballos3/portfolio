---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Cecilia Ceballos — UI/UX Designer">
  <Header />

  <main class="home">
    <section class="hero">
      <p class="hero__text">
        I'm Cecilia, a UI/UX designer with a background in architecture and
        visual design. I help teams and clients turn complexity into experiences
        that feel simple, useful, and right.
      </p>

      <div class="hero__image-wrap">
        <img src="/images/hero-cultr.jpg"          alt="CULTR — a subscription experience for Gen Z"     class="hero__image is-active" />
        <img src="/images/draw/s1-hero.webp"        alt="DRAW — helping people who keep giving up on drawing" class="hero__image" />
        <img src="/images/savr/s1-hero.webp"        alt="SAVR — a meal planning and grocery app"         class="hero__image" style="object-position: center top;" />
        <img src="/images/tirivelo/s1-hero.webp"   alt="TiriVelo — admin dashboard for a pet services platform" class="hero__image" />
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  const images = document.querySelectorAll<HTMLImageElement>('.hero__image');
  let current = 0;

  setInterval(() => {
    images[current].classList.remove('is-active');
    current = (current + 1) % images.length;
    images[current].classList.add('is-active');
  }, 3000);
</script>

<style>
  .home {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* ── Hero ────────────────────────────────────────────── */
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
    padding: 96px 120px 200px;
    width: 100%;
  }

  .hero__text {
    font-family: 'League Spartan', sans-serif;
    font-weight: 400;
    font-size: 32px;
    line-height: 1.35;
    text-align: center;
    max-width: 597px;
    color: #000;
  }

  .hero__image-wrap {
    position: relative;
    width: 580px;
    height: 580px;
    overflow: hidden;
  }

  .hero__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0;
    transition: opacity 1s ease;
  }

  .hero__image.is-active {
    opacity: 1;
  }

  /* ── Mobile ─────────────────────────────────────────── */
  @media (max-width: 768px) {
    .hero {
      padding: 64px 24px 100px;
      gap: 32px;
    }

    .hero__text {
      font-size: 22px;
      max-width: 100%;
    }

    .hero__image-wrap {
      width: 100%;
      height: auto;
      aspect-ratio: 1 / 1;
    }
  }
</style>
