---

<Layout
  title="DRAW — Cecilia Ceballos"
  description="DRAW: A UI/UX case study helping people who keep giving up on drawing. By Cecilia Ceballos."
>
  <Header />

  <main>
    <!-- Desktop slides -->
    <div class="slides slides--desktop" aria-label="DRAW case study">
      {
        desktopSlides.map(({ file, w, h, alt }) => (
          <img
            src={`/images/draw/${file}`}
            alt={alt}
            class="slide"
            width={w}
            height={h}
            loading="lazy"
          />
        ))
      }
    </div>

    <!-- Mobile slides -->
    <div class="slides slides--mobile" aria-label="DRAW case study">
      {
        mobileSlides.map(({ file, w, h, alt }) => (
          <img
            src={`/images/draw/mobile/${file}`}
            alt={alt}
            class="slide"
            width={w}
            height={h}
            loading="lazy"
          />
        ))
      }
    </div>

    <!-- Contact section -->
    <section class="contact" aria-label="Contact">
      <h2 class="contact__heading">Let's work together</h2>
      <p class="contact__body">
        I'm currently looking for full-time UI/UX design roles. If you think I'd
        be a good fit for your team, I'd love to hear from you.
      </p>
      <a href="mailto:studio@ceciliaceballos.com" class="contact__email">
        studio@ceciliaceballos.com
      </a>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* ── Slides container ────────────────────────────────── */
  .slides {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
    padding: 40px 40px 0;
    background: #fff;
  }

  .slide {
    display: block;
    width: 100%;
    max-width: 1360px;
    height: auto;
  }

  /* Desktop visible, mobile hidden */
  .slides--desktop {
    display: flex;
  }

  .slides--mobile {
    display: none;
  }

  /* ── Contact Section ─────────────────────────────────── */
  .contact {
    display: flex;
    flex-direction: column;
    gap: 32px;
    padding: 144px 120px;
    background: #fff;
  }

  .contact__heading {
    font-family: 'League Spartan', sans-serif;
    font-weight: 500;
    font-size: 48px;
    letter-spacing: 2.4px;
    line-height: 1;
    color: #000;
    white-space: nowrap;
  }

  .contact__body {
    font-family: 'League Spartan', sans-serif;
    font-weight: 400;
    font-size: 20px;
    line-height: 32px;
    max-width: 640px;
    color: #000;
  }

  .contact__email {
    font-family: 'League Spartan', sans-serif;
    font-weight: 500;
    font-size: 24px;
    letter-spacing: 2.4px;
    line-height: 1;
    color: #000;
    text-decoration: underline;
    text-underline-offset: 4px;
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }

  .contact__email:hover {
    opacity: 0.5;
  }

  /* ── Mobile ──────────────────────────────────────────── */
  @media (max-width: 768px) {
    .slides--desktop {
      display: none;
    }

    .slides--mobile {
      display: flex;
      gap: 0;
      padding: 0;
    }

    .slides--mobile .slide {
      max-width: 375px;
    }

    .contact {
      padding: 80px 24px;
      gap: 24px;
    }

    .contact__heading {
      font-size: 32px;
      white-space: normal;
    }

    .contact__body {
      font-size: 18px;
      line-height: 28px;
    }

    .contact__email {
      font-size: 18px;
      white-space: normal;
      word-break: break-all;
    }
  }
</style>
