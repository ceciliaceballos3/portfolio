---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="About — Cecilia Ceballos"
  description="Cecilia Ceballos is a UI/UX and visual designer with a background in architecture, graphic design, and illustration."
>
  <Header />

  <main>
    <!-- About content -->
    <div class="about-content">
      <!-- Intro: photo + bio -->
      <section class="intro" aria-label="Introduction">
        <div class="intro__photo-wrap">
          <img
            src="/images/cecilia-photo.jpg"
            alt="Cecilia Ceballos"
            class="intro__photo"
            width="357"
            height="357"
          />
        </div>

        <div class="intro__text">
          <h1 class="intro__name">Cecilia Ceballos</h1>
          <div class="intro__bio">
            <p>
              Cecilia Ceballos is a UI/UX and visual designer with a background
              in architecture, graphic design, and illustration. That path
              wasn't accidental, it reflects how she has always understood
              design: as the result of reading patterns, understanding context,
              and knowing who something is actually for. Aesthetics come last,
              not because they matter less, but because they only work when
              everything else is in place.
            </p>
            <p>
              She started with architecture, where she learned to see systems in
              everything; cities, nature, human behaviour, everyday objects.
              From there she moved into graphic design and brand identity, then
              illustration, then digital product design. Each shift felt like a
              natural extension of the same core interest: how visual
              information guides people, and how to make that guidance honest
              and useful. She's drawn to the moment when colour, composition,
              and hierarchy stop being decorative choices and start doing real
              work.
            </p>
            <p>
              Cecilia is currently completing a UI/UX Design Fellowship at
              Springboard, designing interfaces in Figma and sharpening her
              thinking around interaction design, responsive systems, and
              accessibility. When she's not at a screen, she's probably drawing
              something nearby or painting portraits in watercolour.
            </p>
          </div>
        </div>
      </section>

      <!-- Background: experience / education / tools -->
      <section class="background" aria-label="Background">
        <div class="background__col">
          <h2 class="background__heading">Experience</h2>
          <div class="background__body">
            <p>Productora, Mexico City</p>
            <p>Architecture, Museography &amp; Installation Management</p>
            <p class="spacer">&nbsp;</p>
            <p>Freelance Graphic Design</p>
            <p>Visual Identity &amp; Illustration</p>
            <p class="spacer">&nbsp;</p>
            <p>Tirivelo (Springboard IDP)</p>
            <p>UX Design Intern</p>
          </div>
        </div>

        <div class="background__col">
          <h2 class="background__heading">Education</h2>
          <div class="background__body">
            <p>Springboard</p>
            <p>UI/UX Design Career Track, 2025–2026</p>
            <p class="spacer">&nbsp;</p>
            <p>Universidad Iberoamericana, Mexico City</p>
            <p>Bachelor of Architecture, 2010</p>
          </div>
        </div>

        <div class="background__col">
          <h2 class="background__heading">Tools &amp; Skills</h2>
          <div class="background__body">
            <p>Figma</p>
            <p>Adobe Creative Suite</p>
            <p>User Research</p>
            <p>Wireframing &amp; Prototyping</p>
            <p>Usability Testing</p>
            <p>Design Systems</p>
            <p>Typography &amp; Layout</p>
          </div>
        </div>
      </section>
    </div>

    <!-- Contact section -->
    <section class="contact" aria-label="Contact">
      <h2 class="contact__heading">Let's work together</h2>
      <p class="contact__body">
        I'm currently looking for full-time UI/UX design roles. If you think I'd
        be a good fit for your team, I'd love to hear from you.
      </p>
      <a href="mailto:studio@ceciliaceballos.com" class="contact__email">
        studio@ceciliaceballos.com
      </a>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* ── About Content wrapper ───────────────────────────── */
  .about-content {
    display: flex;
    flex-direction: column;
    gap: 80px;
    padding: 144px 120px 152px;
  }

  /* ── Intro Section ───────────────────────────────────── */
  .intro {
    display: flex;
    gap: 64px;
    align-items: flex-start;
  }

  .intro__photo-wrap {
    flex-shrink: 0;
    width: 357px;
    height: 357px;
    overflow: hidden;
  }

  .intro__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .intro__text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 24px;
    min-width: 0;
  }

  .intro__name {
    font-family: 'League Spartan', sans-serif;
    font-weight: 500;
    font-size: 48px;
    letter-spacing: 2.4px;
    line-height: 1;
    color: #000;
    white-space: nowrap;
  }

  .intro__bio {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .intro__bio p {
    font-family: 'League Spartan', sans-serif;
    font-weight: 400;
    font-size: 20px;
    line-height: 32px;
    color: #000;
  }

  .intro__bio p + p {
    margin-top: 32px;
  }

  /* ── Background Section ──────────────────────────────── */
  .background {
    display: flex;
    gap: 64px;
    align-items: flex-start;
  }

  .background__col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 16px;
    min-width: 0;
  }

  .background__heading {
    font-family: 'League Spartan', sans-serif;
    font-weight: 500;
    font-size: 24px;
    letter-spacing: 2.4px;
    line-height: 1;
    color: #000;
    white-space: nowrap;
  }

  .background__body {
    display: flex;
    flex-direction: column;
  }

  .background__body p {
    font-family: 'League Spartan', sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 28px;
    color: #000;
  }

  .background__body p.spacer {
    line-height: 28px;
    visibility: hidden;
    user-select: none;
  }

  /* ── Contact Section ─────────────────────────────────── */
  .contact {
    display: flex;
    flex-direction: column;
    gap: 32px;
    padding: 144px 120px;
    background: #fff;
  }

  .contact__heading {
    font-family: 'League Spartan', sans-serif;
    font-weight: 500;
    font-size: 48px;
    letter-spacing: 2.4px;
    line-height: 1;
    color: #000;
    white-space: nowrap;
  }

  .contact__body {
    font-family: 'League Spartan', sans-serif;
    font-weight: 400;
    font-size: 20px;
    line-height: 32px;
    max-width: 640px;
    color: #000;
  }

  .contact__email {
    font-family: 'League Spartan', sans-serif;
    font-weight: 500;
    font-size: 24px;
    letter-spacing: 2.4px;
    line-height: 1;
    color: #000;
    text-decoration: underline;
    text-underline-offset: 4px;
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }

  .contact__email:hover {
    opacity: 0.5;
  }

  /* ── Mobile ──────────────────────────────────────────── */
  @media (max-width: 768px) {
    .about-content {
      gap: 56px;
      padding: 64px 24px 80px;
    }

    .intro {
      flex-direction: column;
      gap: 32px;
    }

    .intro__photo-wrap {
      width: 100%;
      height: auto;
      aspect-ratio: 1 / 1;
    }

    .intro__name {
      font-size: 36px;
      white-space: normal;
    }

    .intro__bio p {
      font-size: 18px;
      line-height: 28px;
    }

    .intro__bio p + p {
      margin-top: 28px;
    }

    .background {
      flex-direction: column;
      gap: 40px;
    }

    .background__heading {
      font-size: 20px;
    }

    .background__body p {
      font-size: 16px;
      line-height: 24px;
    }

    .background__body p.spacer {
      line-height: 24px;
    }

    .contact {
      padding: 80px 24px;
      gap: 24px;
    }

    .contact__heading {
      font-size: 32px;
      white-space: normal;
    }

    .contact__body {
      font-size: 18px;
      line-height: 28px;
    }

    .contact__email {
      font-size: 18px;
      white-space: normal;
      word-break: break-all;
    }
  }
</style>
